# ========================================
# Karnaf CRM — Environment Variables
# ========================================

# --- Frontend (Vite) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# --- Supabase Edge Function Secrets ---
# Set via: supabase secrets set KEY=VALUE
#
# SUPABASE_URL              — Auto-provided by Supabase
# SUPABASE_SERVICE_ROLE_KEY — Auto-provided by Supabase
#
# == AI Bot (FREE — Gemini Flash) ==
# GEMINI_API_KEY            — Get free key: https://aistudio.google.com/apikey
#
# == WhatsApp (FREE — Meta Cloud API) ==
# WHATSAPP_TOKEN            — Permanent token from Meta Business
# WHATSAPP_PHONE_ID         — Phone number ID from Meta dashboard
# WHATSAPP_VERIFY_TOKEN     — Webhook verification token (you choose)
#
# == WATI (optional fallback, paid) ==
# WATI_TOKEN                — Only if NOT using Meta Cloud API
# WATI_API_URL              — Default: https://live-mt-server.wati.io
# WATI_WEBHOOK_TOKEN        — Webhook validation for WATI
#
# == Webhooks (optional) ==
# WEBHOOK_API_KEY           — API key for lead-intake & generic webhooks
# FACEBOOK_PAGE_ACCESS_TOKEN — Facebook Graph API for lead enrichment
